{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "config/*.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "src/frontend/dist/**",
        "src/rust-worker/target/release/**"
      ],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": true
    }
  }
}
