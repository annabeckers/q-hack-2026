# ── Database ──────────────────────────────────────
# PostgreSQL (default — full Docker setup):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hackathon

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Neo4j ─────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hackathon

# ── ChromaDB ──────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── AI / Agent Config ────────────────────────────
# Option A: AWS Bedrock (for Strands SDK)
AWS_REGION=us-west-2
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Option B: OpenAI-compatible (for LangGraph)
OPENAI_API_KEY=your-key-here

# Option C: Anthropic direct
ANTHROPIC_API_KEY=your-key-here

# Option D: Google Gemini (for dataloader + A2A)
GOOGLE_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── MCP (Model Context Protocol) ─────────────────
# MCP_SERVER_URL=http://localhost:9000/mcp
# MCP_API_KEY=

# ── Rust Worker ──────────────────────────────────
RUST_WORKER_URL=http://localhost:8080

# ── Security ─────────────────────────────────────
CORS_ORIGINS=*
RATE_LIMIT_RPM=120
WEBHOOK_SECRET=

# ── OpenTelemetry (observability) ────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=hackathon-backend
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ── Scheduler ────────────────────────────────────
SCHEDULER_ENABLED=false

# ── Development ───────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO
